# Tina CMS 配置
# 访问 https://app.tina.io/ 获取这些值
TINA_CLIENT_ID=your_client_id_here
TINA_TOKEN=your_token_here
TINA_BRANCH=main

# 网站配置
SITE_URL=https://yourdomain.com

# Giscus 评论配置（全部配置后自动启用）
PUBLIC_GISCUS_REPO=your-username/your-repo
PUBLIC_GISCUS_REPO_ID=your_repo_id
PUBLIC_GISCUS_CATEGORY=Announcements
PUBLIC_GISCUS_CATEGORY_ID=your_category_id
PUBLIC_GISCUS_MAPPING=pathname
PUBLIC_GISCUS_STRICT=0
PUBLIC_GISCUS_REACTIONS_ENABLED=1
PUBLIC_GISCUS_INPUT_POSITION=bottom
PUBLIC_GISCUS_LANG=zh-CN
PUBLIC_GISCUS_LOADING=lazy

# 访问量统计（可选，默认关闭以减少第三方脚本影响）
PUBLIC_ENABLE_BUSUANZI=false
