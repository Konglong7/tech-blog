---
/**
 * 首页
 * 展示最新的博客文章和个人简介
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

// 获取最新的 3 篇文章
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="恐龙大王的技术博客">
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">
      <!-- Hero 区域 -->
      <section class="max-w-6xl mx-auto px-4 py-20 text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-blue-500 to-purple-600 bg-clip-text text-transparent">
          欢迎来到恐龙大王的技术世界
        </h1>
        <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-8">
          分享前端开发、编程技术和个人见解。探索代码的艺术，记录技术的成长。
        </p>
        <a
          href="/blog"
          class="inline-block px-8 py-3 bg-[var(--accent)] text-white rounded-lg hover:opacity-90 transition-opacity font-medium"
        >
          查看所有文章
        </a>
      </section>

      <!-- 最新文章 -->
      <section class="max-w-6xl mx-auto px-4 py-12">
        <h2 class="text-3xl font-bold mb-8">最新文章</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestPosts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id.replace('.md', '')}
              tags={post.data.tags}
            />
          ))}
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
