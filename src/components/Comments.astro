---
/**
 * Giscus 评论系统组件
 * 基于 GitHub Discussions 的评论系统
 */
const giscusConfig = {
  repo: import.meta.env.PUBLIC_GISCUS_REPO ?? '',
  repoId: import.meta.env.PUBLIC_GISCUS_REPO_ID ?? '',
  category: import.meta.env.PUBLIC_GISCUS_CATEGORY ?? 'Announcements',
  categoryId: import.meta.env.PUBLIC_GISCUS_CATEGORY_ID ?? '',
  mapping: import.meta.env.PUBLIC_GISCUS_MAPPING ?? 'pathname',
  strict: import.meta.env.PUBLIC_GISCUS_STRICT ?? '0',
  reactionsEnabled: import.meta.env.PUBLIC_GISCUS_REACTIONS_ENABLED ?? '1',
  inputPosition: import.meta.env.PUBLIC_GISCUS_INPUT_POSITION ?? 'bottom',
  lang: import.meta.env.PUBLIC_GISCUS_LANG ?? 'zh-CN',
  loading: import.meta.env.PUBLIC_GISCUS_LOADING ?? 'lazy',
};

const commentsEnabled = Boolean(
  giscusConfig.repo && giscusConfig.repoId && giscusConfig.categoryId,
);
---

<div id="comments" class="mt-12 pt-8 border-t border-[var(--border-color)]">
  <h2 class="text-2xl font-bold mb-6">评论</h2>

  {commentsEnabled ? (
    <div class="giscus"></div>
  ) : (
    <div class="rounded-lg border border-dashed border-[var(--border-color)] p-4 text-sm text-[var(--text-secondary)]">
      评论系统暂未开启。配置 `PUBLIC_GISCUS_*` 环境变量后会自动启用。
    </div>
  )}
</div>

{commentsEnabled && (
  <script is:inline define:vars={{ giscusConfig }}>
    /**
     * 动态加载 Giscus 评论系统
     * 主题切换时通过 postMessage 更新主题，而不是反复重建 iframe
     */
    function getGiscusTheme() {
      return document.documentElement.classList.contains('dark') ? 'dark' : 'light';
    }

    function syncGiscusTheme() {
      const iframe = document.querySelector('iframe.giscus-frame');
      iframe?.contentWindow?.postMessage(
        {
          giscus: {
            setConfig: {
              theme: getGiscusTheme(),
            },
          },
        },
        'https://giscus.app',
      );
    }

    function loadGiscus() {
      const container = document.querySelector('.giscus');
      if (!container) return;

      if (container.querySelector('iframe.giscus-frame')) {
        syncGiscusTheme();
        return;
      }

      if (container.querySelector('script[data-giscus-script="true"]')) {
        return;
      }

      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', giscusConfig.repo);
      script.setAttribute('data-repo-id', giscusConfig.repoId);
      script.setAttribute('data-category', giscusConfig.category);
      script.setAttribute('data-category-id', giscusConfig.categoryId);
      script.setAttribute('data-mapping', giscusConfig.mapping);
      script.setAttribute('data-strict', giscusConfig.strict);
      script.setAttribute('data-reactions-enabled', giscusConfig.reactionsEnabled);
      script.setAttribute('data-emit-metadata', '0');
      script.setAttribute('data-input-position', giscusConfig.inputPosition);
      script.setAttribute('data-theme', getGiscusTheme());
      script.setAttribute('data-lang', giscusConfig.lang);
      script.setAttribute('data-loading', giscusConfig.loading);
      script.setAttribute('crossorigin', 'anonymous');
      script.dataset.giscusScript = 'true';
      script.async = true;

      container.appendChild(script);
    }

    function setupGiscus() {
      loadGiscus();

      if (window.__giscusThemeObserver) {
        window.__giscusThemeObserver.disconnect();
      }

      const observer = new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          if (mutation.attributeName === 'class') {
            syncGiscusTheme();
          }
        }
      });

      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      });

      window.__giscusThemeObserver = observer;
    }

    setupGiscus();
    document.addEventListener('astro:after-swap', setupGiscus);
  </script>
)}

<style>
  .giscus {
    min-height: 200px;
  }
</style>
