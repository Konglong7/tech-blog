---
/**
 * 博客文章卡片组件
 * 用于在列表页展示文章摘要
 */
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags: string[];
}

const { title, description, date, slug, tags } = Astro.props;
const formattedDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(date);
---

<article class="group bg-[var(--bg-secondary)] rounded-lg p-6 border border-[var(--border-color)] hover:border-[var(--accent)] transition-all duration-300 hover:shadow-lg">
  <a href={`/blog/${slug}`} class="block">
    <h2 class="text-2xl font-bold mb-2 group-hover:text-[var(--accent)] transition-colors">
      {title}
    </h2>
    <time class="text-sm text-[var(--text-secondary)] block mb-3" datetime={date.toISOString()}>
      {formattedDate}
    </time>
    <p class="text-[var(--text-secondary)] mb-4 line-clamp-2">
      {description}
    </p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {tags.map(tag => (
          <span class="text-xs px-2 py-1 rounded-full border" style="background-color: var(--bg-primary); color: var(--text-secondary); border-color: var(--border-color);">
            #{tag}
          </span>
        ))}
      </div>
    )}
  </a>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
