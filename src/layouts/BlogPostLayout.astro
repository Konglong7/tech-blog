---
/**
 * 博客文章布局组件
 * 用于渲染单篇博客文章，包含文章元信息和评论系统
 */
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Comments from '../components/Comments.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  author: string;
}

const { title, description, date, tags, author } = Astro.props;
const formattedDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(date);
---

<BaseLayout title={title} description={description}>
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1 max-w-4xl mx-auto px-4 py-12 w-full">
      <!-- 文章头部 -->
      <article class="prose">
        <header class="mb-8 border-b border-[var(--border-color)] pb-8">
          <h1 class="text-4xl font-bold mb-4">{title}</h1>
          <div class="flex flex-wrap items-center gap-4 text-sm text-[var(--text-secondary)]">
            <span>作者：{author}</span>
            <span>•</span>
            <time datetime={date.toISOString()}>{formattedDate}</time>
          </div>
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {tags.map(tag => (
                <span class="px-3 py-1 rounded-full text-sm border" style="background-color: var(--bg-secondary); color: var(--text-primary); border-color: var(--border-color);">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <!-- 文章内容 -->
        <div class="article-content">
          <slot />
        </div>
      </article>

      <!-- 评论区 -->
      <div class="mt-16">
        <Comments />
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .article-content {
    line-height: 1.8;
  }
</style>
